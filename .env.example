# ──────────────────────────────────────────────────────────────────────────
# ARIA-OS — Environment variables
#
# Copy this file to `.env` (never committed) and fill in the real values.
# Variables prefixed with PUBLIC_ are injected into the frontend bundle
# via `npm run set-env` and therefore visible in the browser. Only put
# values that are safe to expose (Supabase anon key, public API URL, …).
# ──────────────────────────────────────────────────────────────────────────

# ── Server / Node runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed CORS origins for the API.
# Always include capacitor://localhost so the Android APK can call the API.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,capacitor://localhost,http://localhost

# Number of proxy hops Express should trust for `req.ip` (rate limiting).
# 1 = behind a single reverse proxy (Vercel, Render, Nginx). 0 = no proxy.
TRUST_PROXY=1

# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — server only. Never commit, never expose.
SUPABASE_SERVICE_ROLE_KEY=

# ── Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Override the model if needed. Default: gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-pro

# ── Frontend (PUBLIC_*) — written into src/environments/environment.*.ts
# by `npm run set-env`. ALL VALUES BELOW SHIP IN THE CLIENT BUNDLE.
# ──────────────────────────────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# Base URL of the deployed API (used by the mobile build and by the web
# build when the API lives on a different origin). Leave empty in dev to
# let the Angular dev-server proxy handle /api requests.
PUBLIC_API_URL=
