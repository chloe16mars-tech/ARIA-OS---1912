{
  "name": "aria-os",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "tsx src/server.ts",
    "dev": "concurrently \"cross-env PORT=4000 tsx src/server.ts\" \"npx ng serve --port 3000 --host 0.0.0.0\"",
    "build": "ng build",
    "build:android": "ng build && npx shx cp dist/aria-os/browser/index.csr.html dist/aria-os/browser/index.html && npx cap sync android",
    "generate-assets": "npx @capacitor/assets generate --android",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:ssr:app": "node dist/aria-os/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "21.0.0",
    "@angular/common": "21.0.0",
    "@angular/compiler": "21.0.0",
    "@angular/core": "21.0.0",
    "@angular/forms": "21.0.0",
    "@angular/material": "21.0.0",
    "@angular/platform-browser": "21.0.0",
    "@angular/platform-server": "21.0.0",
    "@angular/router": "21.0.0",
    "@angular/service-worker": "21.0.0",
    "@angular/ssr": "21.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@google/genai": "^1.27.0",
    "@supabase/supabase-js": "^2.104.1",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "motion": "^12.23.24",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "21.0.0",
    "@angular/cli": "21.0.0",
    "@angular/compiler-cli": "21.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.1",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.0"
  }
}
